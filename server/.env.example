# ─── Core ────────────────────────────────────────────────────────────────
# Port the HTTP + WebSocket + signaling server listens on.
PORT=4000

# Public origin of the web client, used to build invite links and to lock down CORS.
# In local dev the Vite client runs on 5173.
WEB_ORIGIN=http://localhost:5173

# Comma-separated list of origins allowed to call the API / open a socket.
# Defaults to WEB_ORIGIN if left blank.
CORS_ORIGINS=http://localhost:5173

# ─── Secrets (CHANGE THESE) ──────────────────────────────────────────────
# Signing key for agent session tokens. Use a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=dev-only-change-me-to-a-48-byte-random-string

# Separate signing key for customer invite tokens, so leaking one never grants the other.
INVITE_SECRET=dev-only-change-me-too-different-from-above

# How long an agent stays logged in.
SESSION_TOKEN_TTL=12h

# How long an invite link remains valid after it is created.
INVITE_TOKEN_TTL=4h

# ─── Media (SFU) ─────────────────────────────────────────────────────────
# IP address the SFU advertises in ICE candidates.
# Leave blank for local development (host candidates are gathered automatically).
# In cloud deployment set this to the server's public IPv4 address.
ANNOUNCED_IP=

# Optional STUN server for NAT traversal when client and server are on different networks.
# Not needed for localhost or same-LAN demos.
STUN_URL=stun:stun.l.google.com:19302

# ─── Storage ─────────────────────────────────────────────────────────────
# Where the SQLite database file lives (created automatically).
DATABASE_PATH=./data/atomquest.db

# Where recordings and shared chat files are written.
STORAGE_DIR=./storage

# Maximum size for a single shared file, in megabytes.
MAX_UPLOAD_MB=25

# ─── Reconnect ───────────────────────────────────────────────────────────
# Grace window (seconds) a dropped participant is held before being treated as left.
RECONNECT_GRACE_SECONDS=20

# ─── Seed agent (created by `npm run seed`) ──────────────────────────────
SEED_AGENT_EMAIL=agent@atomquest.dev
SEED_AGENT_PASSWORD=Demo!Agent1
SEED_AGENT_NAME=Riya Sharma

# ─── Logging ─────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
NODE_ENV=development
