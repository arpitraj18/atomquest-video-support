              <mxPoint x="165" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Session Service to DB -->
        <mxCell id="flow5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#d6b656;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="session-svc" target="repos">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Repos to SQLite -->
        <mxCell id="flow6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#d6b656;strokeWidth=2;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="repos" target="sqlite">
          <mxGeometry relative="1" as="geometry" />
