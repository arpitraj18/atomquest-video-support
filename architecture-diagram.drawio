        </mxCell>

        <!-- Logging -->
        <mxCell id="logging" value="&lt;b&gt;Structured Logging&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Pino + pino-http&lt;br&gt;&lt;br&gt;• Request logging&lt;br&gt;• Error tracking&lt;br&gt;• Event audit trail&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b85450;shadow=1;fontSize=11;" vertex="1" parent="1">
