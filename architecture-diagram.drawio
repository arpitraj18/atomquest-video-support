        <!-- ========== SECURITY CALLOUT ========== -->
        <mxCell id="security-group" value="&lt;b&gt;SECURITY &amp; ACCESS CONTROL&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666;verticalAlign=top;align=left;spacingLeft=14;fontSize=13;fontStyle=1;arcSize=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="730" width="750" height="160" as="geometry" />
        </mxCell>

        <mxCell id="sec1" value="&lt;b&gt;Dual JWT Secrets&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Agent tokens &amp; Invite&lt;br&gt;tokens use separate&lt;br&gt;signing secrets.&lt;br&gt;Invite tokens are&lt;br&gt;session-scoped.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="770" width="160" height="100" as="geometry" />
        </mxCell>

        <mxCell id="sec2" value="&lt;b&gt;Role Enforcement&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;• requireAuth guard&lt;br&gt;• requireAgent guard&lt;br&gt;• requireSessionAccess&lt;br&gt;• Socket auth middleware&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1030" y="770" width="170" height="100" as="geometry" />
        </mxCell>

        <mxCell id="sec3" value="&lt;b&gt;Upload Security&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;• MIME type allowlist&lt;br&gt;• Size limit (10MB)&lt;br&gt;• Generated filenames&lt;br&gt;• No path traversal&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1230" y="770" width="160" height="100" as="geometry" />
        </mxCell>

        <mxCell id="sec4" value="&lt;b&gt;Network Security&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;• Helmet headers&lt;br&gt;• CORS whitelist&lt;br&gt;• Rate limiting&lt;br&gt;• bcrypt passwords&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1420" y="770" width="120" height="100" as="geometry" />
        </mxCell>


        <!-- ========== FLOW ARROWS ========== -->

        <!-- Client to Server (REST) -->
        <mxCell id="flow1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#6c8ebf;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="agent-console" target="routes">
